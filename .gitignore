# ============================================================
#  AI Test Prioritization — .gitignore
# ============================================================

# ------------------------------------------------------------
# 🔐 Environment & Secrets — NEVER commit these
# ------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.test
*.key
*.pem

# ------------------------------------------------------------
# 📦 Node Modules
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ------------------------------------------------------------
# 🏗️ TypeScript Build Output
# ------------------------------------------------------------
dist/
build/
out/
*.js.map
*.d.ts.map

# ------------------------------------------------------------
# 🎭 Playwright — Test Results & Reports
# ------------------------------------------------------------
playwright-report/
test-results/
test-results/screenshots/
/blob-report/
/playwright/.cache/
*.zip

# ------------------------------------------------------------
# 📊 Generated Reports — recreated on every run
# ------------------------------------------------------------
reports/priority-dashboard.html

# ------------------------------------------------------------
# 📋 Generated Execution Plan — recreated on every run
# ------------------------------------------------------------
test-history/test-execution-order.json

# ------------------------------------------------------------
# 💻 VS Code
# ------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ------------------------------------------------------------
# 🍎 macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# 🪟 Windows
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------------------------------------
# 🐧 Linux
# ------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*

# ------------------------------------------------------------
# 📝 Logs
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*
pids/
*.pid
*.seed

# ------------------------------------------------------------
# ⚙️ Runtime & Cache
# ------------------------------------------------------------
.cache/
.temp/
.tmp/
*.tmp
.nyc_output/
coverage/

# ------------------------------------------------------------
# ✅ What IS committed to GitHub
# ------------------------------------------------------------
# src/**/*.ts              → all source files
# tests/**/*.spec.ts       → all test files
# test-history/history.json → CI history data
# playwright.config.ts     → playwright config
# package.json             → dependencies
# tsconfig.json            → typescript config
# .github/workflows/       → CI pipeline
# README.md                → documentation
# .env.example             → template (no real keys)